# NE PAS COMMITTER ce fichier avec de vraies valeurs.
# Copier vers secrets.yaml et remplir les valeurs, ou passer via Ansible --extra-vars.
apiVersion: v1
kind: Secret
metadata:
  name: audit-secrets
  namespace: security-audit
type: Opaque
stringData:
  DB_URL: "postgresql://audit:CHANGEME@postgresql:5432/audit_db"
  DB_PASSWORD: "CHANGEME"
  SLACK_TOKEN: "xoxb-CHANGEME"
  SMTP_HOST: "smtp.example.com"
  SMTP_PORT: "587"
  SMTP_USER: "CHANGEME"
  SMTP_PASS: "CHANGEME"
  SMTP_FROM: "audit@example.com"
