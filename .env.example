# ──────────────────────────────────────────────────────────────────────────────
# Argus — variables d'environnement
# ──────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en `.env` et adaptez les valeurs.
# Le minimum pour démarrer en local est POSTGRES_PASSWORD.
# Pour activer l'agent IA (triage, remédiation, chat) configurez la section LLM.
#
# IMPORTANT : pas de commentaire inline sur les valeurs (Docker Compose les inclut
# dans la valeur). Les commentaires doivent être sur leur propre ligne.
# ──────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=audit_db
POSTGRES_USER=audit
# Requis. Choisir un mot de passe fort pour la production.
POSTGRES_PASSWORD=change_me


# ──────────────────────────────────────────────────────────────────────────────
# AI Agent — Bring Your Own Key (BYOK)
# ──────────────────────────────────────────────────────────────────────────────
# Choisissez UN fournisseur LLM et fournissez sa clé API.
# Argus marche sans IA (collecte + dashboard) ; l'agent active triage automatique,
# remédiation et chat. Coût typique : ~2 USD/mois pour ~50 sites scannés.
# ──────────────────────────────────────────────────────────────────────────────

# Provider : anthropic | openai | google | ollama
LLM_PROVIDER=anthropic

# Vide = défaut du provider :
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
#   google    -> gemini-1.5-flash
#   ollama    -> llama3.1:8b
LLM_MODEL=

# Clé API — fournir UNIQUEMENT celle du provider choisi
# Anthropic : https://console.anthropic.com/
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Endpoint custom (proxy LLM, Ollama, etc.). Pour Ollama local :
#   LLM_PROVIDER=ollama
#   LLM_API_BASE=http://host.docker.internal:11434
LLM_API_BASE=

# Plafond de coût journalier en USD. L'agent renvoie 429 quand atteint.
LLM_DAILY_BUDGET_USD=2.00

# Limite de findings par triage (au-delà : tronqué pour économiser tokens)
TRIAGE_MAX_FINDINGS=100

# Hook collector -> agent. Mettre à false pour désactiver le triage automatique.
AGENT_TRIAGE_ENABLED=true


# ── Alerts — Slack ────────────────────────────────────────────────────────────
# Bot token avec scope chat:write
SLACK_TOKEN=


# ── Alerts — Email (SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=audit@example.com


# ── Reports ───────────────────────────────────────────────────────────────────
REPORT_LOOKBACK_HOURS=24


# ── WPScan (optionnel) ────────────────────────────────────────────────────────
# Clé gratuite sur https://wpscan.com/register — augmente la base CVE WordPress
WPSCAN_API_TOKEN=


# ── Dashboard (authentification HTTP Basic) ──────────────────────────────────
# Laisser vide pour un accès sans mot de passe (usage local uniquement)
DASHBOARD_USER=
DASHBOARD_PASSWORD=


# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me


# ── Kubernetes / Ansible (uniquement pour `make bootstrap`) ──────────────────
REGISTRY=ghcr.io/Numberbis
IMAGE_TAG=latest


# ── Logs ─────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
