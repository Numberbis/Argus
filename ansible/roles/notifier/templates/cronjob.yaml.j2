apiVersion: batch/v1
kind: CronJob
metadata:
  name: notifier
  namespace: {{ k8s_namespace }}
spec:
  schedule: "{{ schedules.notifier }}"
  concurrencyPolicy: Forbid
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      backoffLimit: 1
      activeDeadlineSeconds: 120
      template:
        spec:
          restartPolicy: OnFailure
          securityContext:
            runAsNonRoot: true
            runAsUser: 1000
          containers:
            - name: notifier
              image: ghcr.io/{{ registry_org }}/audit-notifier:{{ image_tag }}
              imagePullPolicy: Always
              envFrom:
                - secretRef:
                    name: audit-secrets
              resources:
                requests:
                  cpu: "50m"
                  memory: "64Mi"
                limits:
                  cpu: "100m"
                  memory: "128Mi"
              securityContext:
                allowPrivilegeEscalation: false
                readOnlyRootFilesystem: true
